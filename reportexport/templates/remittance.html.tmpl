<!DOCTYPE html>
<html lang="en-CA">
<head>
  <meta charset="utf-8" />
  <title>Remittance report #{{.ReportNumber}} — {{.CompanyLegalName}}</title>
  <style>
    @page { size: letter; margin: 12mm; }
    * { box-sizing: border-box; }
    body {
      font-family: "Segoe UI", Arial, sans-serif;
      font-size: 11px;
      color: #111;
      max-width: 720px;
      margin: 0 auto;
      padding: 16px;
    }
    h1 {
      font-size: 14px;
      text-align: center;
      letter-spacing: 0.06em;
      margin: 0 0 8px;
    }
    .meta {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 10px;
      margin-bottom: 12px;
      border-bottom: 1px solid #333;
      padding-bottom: 8px;
    }
    table.grid {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10px;
    }
    table.grid th, table.grid td {
      border: 1px solid #333;
      padding: 4px 8px;
      text-align: right;
    }
    table.grid th:first-child, table.grid td:first-child {
      text-align: left;
      font-weight: 600;
    }
    .hdr { background: #e8e8e8; font-weight: 700; text-align: center !important; }
    .section { font-weight: 700; margin-top: 10px; margin-bottom: 4px; font-size: 11px; }
    .footer {
      margin-top: 16px;
      font-size: 10px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .box {
      border: 1px solid #333;
      padding: 8px;
    }
    @media print {
      body { padding: 0; }
      a { color: inherit; text-decoration: none; }
    }
  </style>
</head>
<body>
  <h1>CRA SOURCE DEDUCTIONS</h1>
  <div class="meta">
    <div><strong>{{.CompanyLegalName}}</strong></div>
    <div>Payroll year: <strong>{{.PayrollYear}}</strong></div>
    <div>Report #: <strong>{{.ReportNumber}}</strong></div>
    <div>Payment date: <strong>{{.PaymentDateDisplay}}</strong></div>
  </div>

  <table class="grid">
    <tr class="hdr">
      <th></th>
      <th>Previous</th>
      <th>Current</th>
    </tr>
    <tr>
      <td>Total gross payroll</td>
      <td>{{.TotalGrossPayroll.Previous}}</td>
      <td>{{.TotalGrossPayroll.Current}}</td>
    </tr>
  </table>

  <div class="section">CANADA PENSION PLAN</div>
  <table class="grid">
    <tr><td>Employee CPP contribution</td><td>{{.CPP.Employee.Previous}}</td><td>{{.CPP.Employee.Current}}</td></tr>
    <tr><td>Employer CPP contribution</td><td>{{.CPP.Employer.Previous}}</td><td>{{.CPP.Employer.Current}}</td></tr>
    <tr><td>Total CPP contribution</td><td>{{.CPP.Total.Previous}}</td><td>{{.CPP.Total.Current}}</td></tr>
  </table>

  <div class="section">EMPLOYMENT INSURANCE</div>
  <table class="grid">
    <tr><td>Employee EI premium</td><td>{{.EI.Employee.Previous}}</td><td>{{.EI.Employee.Current}}</td></tr>
    <tr><td>Employer EI premium</td><td>{{.EI.Employer.Previous}}</td><td>{{.EI.Employer.Current}}</td></tr>
    <tr><td>Total EI premium</td><td>{{.EI.Total.Previous}}</td><td>{{.EI.Total.Current}}</td></tr>
  </table>

  <table class="grid">
    <tr><td>Federal tax</td><td>{{.FederalTax.Previous}}</td><td>{{.FederalTax.Current}}</td></tr>
    <tr class="hdr"><td>Total to remit</td><td>{{.TotalToRemit.Previous}}</td><td>{{.TotalToRemit.Current}}</td></tr>
  </table>

  <div class="footer">
    <div class="box">
      <div><strong>Account numbers</strong></div>
      <div>CRA: {{.CRAAccountNumber}}</div>
    </div>
    <div class="box">
      <div>Number of employees: <strong>{{.EmployeeCount}}</strong></div>
      <div>Remittance frequency: <strong>{{.RemittanceFrequency}}</strong></div>
      <div>Total payments (CRA): <strong>{{.TotalPaymentsCRA}}</strong></div>
      <div>Total remittance: <strong>{{.TotalRemittance}}</strong></div>
    </div>
  </div>
  {{if .PrintedAt}}
  <p style="font-size:9px;margin-top:12px;color:#444;">{{.SourcePaymentNote}} · Printed {{.PrintedAt}}</p>
  {{end}}
  <p style="font-size:9px;color:#666;margin-top:8px;">— End of report —</p>
</body>
</html>
